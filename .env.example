# .env.example — Copia este archivo a .env y rellena los valores reales.
# El archivo .env NUNCA se versiona (está en .gitignore).

# Clave secreta de la Agencia. Los clientes deben enviarla en el header X-API-KEY
# para usar los endpoints de escritura (POST).
AGENCIA_API_KEY=your_secret_api_key_here

# URL de la API pública externa usada en GET /briefing/{nombre}.
# Por defecto usa Advice Slip (https://api.adviceslip.com/advice).
EXTERNAL_API_URL=https://api.adviceslip.com/advice
